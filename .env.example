# Variáveis de Ambiente — SRG ControlCore FrontEnd
# Copie este ficheiro para .env e preencha os valores correctos
# NUNCA commite o ficheiro .env — apenas o .env.example

# ─── API ────────────────────────────────────────────────
# URL base da API do backend NestJS
VITE_API_URL=http://localhost:3000/api/v1

# ─── SERVIDOR VITE ──────────────────────────────────────
# Porta onde o servidor de desenvolvimento irá escutar
VITE_PORT=5173
